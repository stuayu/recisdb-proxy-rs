; =====================================================
; BonDriver_NetworkProxy 設定ファイル
; =====================================================
; このファイルを BonDriver_NetworkProxy.ini にリネームし、
; DLLと同じディレクトリに配置してください。
;
; 環境変数でも設定可能です (BONDRIVER_PROXY_* プレフィックス):
;   BONDRIVER_PROXY_SERVER     → Address
;   BONDRIVER_PROXY_TUNER      → Tuner
;   BONDRIVER_PROXY_PRIORITY   → Priority
;   BONDRIVER_PROXY_EXCLUSIVE  → Exclusive
;   BONDRIVER_PROXY_TLS        → TLS
;   BONDRIVER_PROXY_CA_CERT    → TLSCACert
;   BONDRIVER_PROXY_SERVICE_FILTER → ServiceFilter
;   BONDRIVER_LOG_LEVEL        → LogLevel

; =====================================================
; サーバー接続設定
; =====================================================
[Server]
; プロキシサーバーのアドレス (IP:ポート)
; recisdb-proxy サーバーのアドレスを指定してください
Address = 127.0.0.1:40070

; =====================================================
; チューナー選択
; =====================================================
; 接続先のチューナーパスまたはグループ名 (省略可)
; 以下のいずれかの形式で指定できます:
;   - フルパス指定: C:\BonDriver\BonDriver_PX-MLT1.dll
;   - グループ名指定: PX-MLT (MLT1, MLT2 等から自動選択)
; 空欄の場合、サーバー側のデフォルトチューナーが使用されます
Tuner =

; =====================================================
; 接続タイムアウト設定
; =====================================================
; 接続タイムアウト (ミリ秒, デフォルト: 5000)
; サーバーへの初回接続が完了するまでの待ち時間
ConnectTimeout = 5000

; 受信タイムアウト (ミリ秒, デフォルト: 30000)
; データ受信が途絶えた場合に切断と判定するまでの時間
ReadTimeout = 30000

; =====================================================
; チューナーグループ選択
; =====================================================
; グループ名 (例: PX-MLT) を指定した場合、サーバーは以下の条件で
; グループ内から最適なドライバーを自動選択します:
;   - 各チューナーの現在の負荷状況
;   - クライアントの優先度レベル
;   - 排他ロックの要求状況

; クライアント優先度 (デフォルト: 0)
; 数値が大きいほど優先的にチューナーが割り当てられます
Priority = 0

; 排他ロックモード (デフォルト: 0)
; 1 または true: チューナーを排他的に使用 (他のクライアントは切断されます)
; 0 または false: 共有アクセスを許可 (同一チャンネルの場合TSストリームを共有)
Exclusive = 0

; =====================================================
; サービスフィルタモード
; =====================================================
; TSストリーム (トランスポートストリーム) の配信方式を制御します。
;   all    — 全サービス (NID+TSID上の全番組) を受信します。
;            録画用途やマルチサービス受信に使用。(デフォルト)
;   single — 選択したサービス (SID) のみを受信します。
;            不要な番組のパケットをフィルタし帯域を削減します。
;            PATは対象サービスのみに書き換えられます。
;            単一チャンネルの視聴・デコードに最適。
ServiceFilter = all

; =====================================================
; TLS設定 (tls フィーチャーが有効な場合のみ)
; =====================================================
; TLS暗号化を有効にする
; 1 または true で有効化
; TLS = 0

; CA証明書のパス (PEM形式)
; 省略した場合、システムのルート証明書が使用されます
; TLSCACert = ca.pem

; =====================================================
; ログ設定
; =====================================================
[Logging]
; ログレベル (ログファイルおよび env_logger の出力レベル)
; 指定可能な値 (大文字小文字不問): off, error, warn, info, debug, trace
; デフォルト: warn (警告とエラーのみ出力)
; 接続やチャンネルの診断には info を推奨
; 詳細なトラブルシューティングには debug または trace (ログが大量になります)
LogLevel = warn
